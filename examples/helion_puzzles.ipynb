      "source": [
        "## Puzzle 7: Simple FlashAttention\n",
        "\n",
        "A scalar version of FlashAttention."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "def flashatt_spec(q: Tensor, k: Tensor, v: Tensor) -> Tensor:\n",
        "    x = q @ k.transpose(-2, -1)\n",
        "    attention_scores = torch.softmax(x, dim=-1)\n",
        "    return attention_scores @ v\n",
        "\n",
        "@helion.kernel(config={\"block_sizes\": [1, 16]}, static_shapes=True)\n",
        "def flashatt_kernel(q: torch.Tensor, k: torch.Tensor, v: torch.Tensor) -> torch.Tensor:\n",
        "    # Get tensor size\n",
        "    seq_len_q, head_dim = q.shape\n",
        "    seq_len_kv = k.size(0)\n",
        "\n",
        "    # Create output tensor\n",
        "    out = torch.empty_like(q)\n",
        "\n",
        "    block_size_m = hl.register_block_size(seq_len_q)\n",
        "    block_size_n = hl.register_block_size(seq_len_kv)\n",
        "    # Process each query position\n",
        "    for tile_m in hl.tile(seq_len_q, block_size=block_size_m):\n",
        "        q_tile = q[tile_m, :]\n",
        "\n",
        "        # Initialize vars for online softmax\n",
        "        mi = hl.full([tile_m, 1], float(\"-inf\"), dtype=torch.float32)\n",
        "        acc = hl.zeros([tile_m, head_dim], dtype=torch.float32)\n",
        "        lse = hl.zeros([tile_m, 1], dtype=torch.float32)\n",
        "\n",
        "        # Process in tiles for better cache efficiency\n",
        "        for tile_kv in hl.tile(seq_len_kv, block_size=block_size_n):\n",
        "            k_tile = k[tile_kv, :]\n",
        "            v_tile = v[tile_kv, :]\n",
        "\n",
        "            # Compute attention scores\n",
        "            scores = torch.mm(q_tile, k_tile.t())\n",
        "\n",
        "            # Rescale accumulator\n",
        "            local_max = torch.amax(scores, dim=1)[:, None]\n",
        "            m_ij = torch.maximum(mi, local_max)\n",
        "            alpha = torch.exp(mi - m_ij)\n",
        "\n",
        "            # Update LSE\n",
        "            p = torch.exp(scores - m_ij)\n",
        "            lse = lse * alpha + torch.sum(p, dim=1)[:, None]\n",
        "\n",
        "            # -- scale and update acc --\n",
        "            acc = acc * alpha + torch.mm(p, v_tile)\n",
        "\n",
        "            # Update max_val\n",
        "            mi = m_ij\n",
        "\n",
        "        # Final Rescale\n",
        "        acc = acc / lse\n",
        "        out[tile_m, :] = acc\n",
        "\n",
        "    return out\n",
        "\n",
        "# Test the kernel\n",
        "q = torch.randn(256, 16, device=\"cuda\")\n",
        "k = torch.randn(256, 16, device=\"cuda\")\n",
        "v = torch.randn(256, 16, device=\"cuda\")\n",
        "test_kernel(flashatt_kernel, flashatt_spec, q, k, v)\n",
        "compare_implementations(flashatt_kernel, flashatt_spec, q, k, v)"
      ]
    },
    {
